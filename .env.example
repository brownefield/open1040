# Open1040 — Environment Variables
# Copy this file to .env.local and fill in values.

# ---- Enhanced W-2 Reader (Optional) ----
# Required only if you want to enable the AI-powered W-2 reader.
# Get an API key from https://console.anthropic.com
# Without this key, the app still works — users just enter W-2 data manually
# or use the in-browser OCR reader.
ANTHROPIC_API_KEY=
